<!-- SEÇÃO 1: IDENTIFICAÇÃO -->
<div class="card" id="section-0">
  <div class="section-label">Seção 1 de 3</div>
  <div class="section-title">Identificação</div>

  <div class="field" id="f-nome">
    <label>Nome Completo <span class="req">*</span></label>
    <input type="text" id="nome" placeholder="Digite seu nome completo">
    <div class="error-msg">Este campo é obrigatório.</div>
  </div>

  <div class="field" id="f-estadoCivil">
    <label>Estado Civil <span class="req">*</span></label>
    <input type="text" id="estadoCivil" placeholder="Ex: Solteiro(a), Casado(a), Divorciado(a)...">
    <div class="error-msg">Este campo é obrigatório.</div>
  </div>

  <div class="field" id="f-filhos">
    <label>Número de Filhos</label>
    <input type="text" id="filhos" placeholder="Ex: 2">
  </div>

  <div class="field" id="f-religiao">
    <label>Religião</label>
    <input type="text" id="religiao" placeholder="Ex: Católica, Evangélica, Espírita...">
  </div>

  <div class="field">
    <label>Praticante de alguma religião? <span class="req">*</span></label>
    <div class="radio-group" id="rg-praticante">
      <label><input type="radio" name="praticante" value="Sim"><span class="radio-pill">Sim</span></label>
      <label><input type="radio" name="praticante" value="Não"><span class="radio-pill">Não</span></label>
    </div>
  </div>

  <div class="field" id="f-reside">
    <label>Com quem reside atualmente? <span class="req">*</span></label>
    <input type="text" id="reside" placeholder="Ex: Família, Cônjuge, Sozinho(a)...">
