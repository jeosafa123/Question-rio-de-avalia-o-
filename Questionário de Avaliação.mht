@charset "utf-8";

:root { --bg: #f5f3ef; --surface: #ffffff; --accent: #3d6b74; --accent-light: #e8f1f3; --accent-mid: #a8c8ce; --text: #1e2c2f; --muted: #7a9198; --border: #dde8ea; --danger: #c0392b; --success: #2d7a5e; --radius: 12px; --shadow: 0 4px 32px rgba(61,107,116,0.10); }

*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

body { font-family: "DM Sans", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 0px 0px 60px; }

.header { width: 100%; background: var(--accent); padding: 36px 24px 28px; text-align: center; position: relative; overflow: hidden; }

.header::before { content: ""; position: absolute; inset: 0px; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); opacity: 0.5; }

.header-inner { position: relative; z-index: 1; }

.header h1 { font-family: "Cormorant Garamond", serif; font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 300; color: rgb(255, 255, 255); letter-spacing: 0.04em; line-height: 1.2; }

.header p { color: rgba(255, 255, 255, 0.7); font-size: 0.85rem; margin-top: 6px; font-weight: 300; letter-spacing: 0.06em; text-transform: uppercase; }

.progress-wrap { width: 100%; max-width: 700px; padding: 28px 24px 0px; }

.progress-steps { display: flex; gap: 0px; align-items: center; margin-bottom: 8px; }

.step-item { display: flex; flex-direction: column; align-items: center; flex: 1 1 0%; position: relative; }

.step-item:not(:last-child)::after { content: ""; position: absolute; top: 15px; left: 50%; width: 100%; height: 2px; background: var(--border); z-index: 0; transition: background 0.4s; }

.step-item.done:not(:last-child)::after { background: var(--accent); }

.step-dot { width: 30px; height: 30px; border-radius: 50%; background: var(--surface); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 500; color: var(--muted); position: relative; z-index: 1; transition: 0.4s; }

.step-item.active .step-dot { background: var(--accent); border-color: var(--accent); color: white; box-shadow: 0 0 0 4px var(--accent-light); }

.step-item.done .step-dot { background: var(--accent); border-color: var(--accent); color: white; }

.step-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-top: 6px; font-weight: 500; transition: color 0.3s; }

.step-item.active .step-label { color: var(--accent); }

.card { width: 100%; max-width: 700px; background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); margin: 20px 24px 0px; padding: 40px 40px 36px; animation: 0.45s ease 0s 1 normal both running fadeUp; }

@keyframes fadeUp { 
  0% { opacity: 0; transform: translateY(18px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.section-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); font-weight: 500; margin-bottom: 6px; }

.section-title { font-family: "Cormorant Garamond", serif; font-size: 1.7rem; font-weight: 400; color: var(--text); line-height: 1.3; margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border); }

.field { margin-bottom: 24px; }

.field label { display: block; font-size: 0.82rem; font-weight: 500; color: var(--text); margin-bottom: 8px; line-height: 1.4; }

.field label .req { color: var(--accent); margin-left: 2px; }

input[type="text"], textarea { width: 100%; border: 1.5px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: "DM Sans", sans-serif; font-size: 0.9rem; color: var(--text); background: var(--bg); outline: none; transition: border-color 0.25s, box-shadow 0.25s; }

input[type="text"]:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-light); background: rgb(255, 255, 255); }

textarea { resize: vertical; min-height: 72px; }

.radio-group { display: flex; flex-wrap: wrap; gap: 8px; }

.radio-group label { display: flex; align-items: center; gap: 0px; cursor: pointer; margin: 0px; }

.radio-group input[type="radio"] { display: none; }

.radio-pill { padding: 8px 18px; border-radius: 50px; border: 1.5px solid var(--border); font-size: 0.82rem; font-weight: 400; color: var(--muted); background: var(--bg); cursor: pointer; transition: 0.2s; user-select: none; }

.radio-group input[type="radio"]:checked + .radio-pill { background: var(--accent); border-color: var(--accent); color: rgb(255, 255, 255); font-weight: 500; box-shadow: rgba(61, 107, 116, 0.25) 0px 2px 10px; }

.radio-pill:hover { border-color: var(--accent-mid); color: var(--accent); }

.freq-scale { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }

.freq-scale label { display: flex; flex-direction: column; align-items: center; text-align: center; margin: 0px; cursor: pointer; }

.freq-scale input[type="radio"] { display: none; }

.freq-btn { width: 100%; padding: 10px 4px; border-radius: 8px; border: 1.5px solid var(--border); font-size: 0.75rem; font-weight: 400; color: var(--muted); background: var(--bg); cursor: pointer; transition: 0.2s; text-align: center; line-height: 1.2; }

.freq-scale input[type="radio"]:checked + .freq-btn { background: var(--accent); border-color: var(--accent); color: rgb(255, 255, 255); font-weight: 500; }

.freq-btn:hover { border-color: var(--accent-mid); color: var(--accent); background: var(--accent-light); }

.question-item { padding: 20px 0px; border-bottom: 1px solid var(--border); }

.question-item:last-child { border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }

.question-text { font-size: 0.88rem; font-weight: 400; color: var(--text); margin-bottom: 12px; line-height: 1.5; }

.question-num { font-weight: 500; color: var(--accent); margin-right: 4px; }

.declaration-box { background: var(--accent-light); border: 1.5px solid var(--accent-mid); border-radius: 10px; padding: 20px 22px; }

.declaration-text { font-size: 0.85rem; color: var(--text); line-height: 1.6; margin-bottom: 16px; font-style: italic; }

.check-row { display: flex; align-items: center; gap: 12px; cursor: pointer; }

.check-row input[type="checkbox"] { display: none; }

.custom-check { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--accent); background: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: 0.2s; }

.check-row input[type="checkbox"]:checked ~ .custom-check { background: var(--accent); }

.check-row input[type="checkbox"]:checked ~ .custom-check::after { content: "✓"; color: white; font-size: 13px; font-weight: 700; }

.check-label { font-size: 0.88rem; font-weight: 500; color: var(--accent); }

.nav-row { display: flex; justify-content: space-between; align-items: center; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); }

.btn { padding: 12px 28px; border-radius: 8px; font-family: "DM Sans", sans-serif; font-size: 0.88rem; font-weight: 500; cursor: pointer; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; transition: 0.25s; letter-spacing: 0.02em; }

.btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--muted); }

.btn-outline:hover { border-color: var(--accent); color: var(--accent); }

.btn-primary { background: var(--accent); color: white; box-shadow: rgba(61, 107, 116, 0.25) 0px 4px 16px; }

.btn-primary:hover { background: rgb(47, 87, 96); transform: translateY(-1px); box-shadow: rgba(61, 107, 116, 0.32) 0px 6px 20px; }

.btn-success { background: var(--success); color: white; box-shadow: rgba(45, 122, 94, 0.25) 0px 4px 16px; }

.btn-success:hover { background: rgb(35, 98, 73); }

.success-screen { text-align: center; padding: 20px 0px; }

.success-icon { width: 72px; height: 72px; background: var(--accent-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0px auto 24px; border: 2px solid var(--accent-mid); }

.success-screen h2 { font-family: "Cormorant Garamond", serif; font-size: 1.9rem; font-weight: 400; margin-bottom: 12px; }

.success-screen p { color: var(--muted); font-size: 0.9rem; line-height: 1.6; }

.error-msg { font-size: 0.75rem; color: var(--danger); margin-top: 5px; display: none; }

.field.has-error input, .field.has-error textarea { border-color: var(--danger); }

.field.has-error .error-msg { display: block; }

@media (max-width: 540px) {
  .card { padding: 28px 20px 24px; margin: 16px 12px 0px; }
  .freq-scale { grid-template-columns: repeat(2, 1fr); }
  .section-title { font-size: 1.4rem; }
}
